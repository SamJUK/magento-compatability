---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Magento 2 and MageOS service compatibility — tested, not guessed.' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title} — Magento 2 & MageOS Compatibility</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-full bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 flex flex-col">

    <!-- ── Navigation ────────────────────────────────────────────────────── -->
    <header class="sticky top-0 z-30 border-b border-zinc-200 dark:border-zinc-800 bg-white/90 dark:bg-zinc-950/90 backdrop-blur">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-zinc-900 dark:text-white">
          <svg class="w-5 h-5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
          </svg>
          <span>M2 Compatibility</span>
        </a>

        <nav class="flex items-center gap-1 text-sm">
          <a href="/magento" class="px-3 py-1.5 rounded-lg text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">Magento</a>
          <a href="/mageos" class="px-3 py-1.5 rounded-lg text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">MageOS</a>
          <a href="/software" class="px-3 py-1.5 rounded-lg text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">Software</a>
          <a href="/api" class="px-3 py-1.5 rounded-lg text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">API</a>
          {import.meta.env.DEV && (
            <button
              id="dev-refresh-btn"
              title="Refresh matrix & results cache (dev only)"
              class="ml-2 flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-amber-100 text-amber-800 border border-amber-300 hover:bg-amber-200 dark:bg-amber-900/40 dark:text-amber-300 dark:border-amber-700 dark:hover:bg-amber-900/70 transition-colors cursor-pointer"
            >
              <svg class="w-3.5 h-3.5" id="dev-refresh-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13.5 2.5A7 7 0 1 1 2.5 8"/>
                <polyline points="1 2 2.5 8 8.5 6.5"/>
              </svg>
              Refresh
            </button>
          )}
        </nav>
      </div>
    </header>

    <div class="bg-yellow-50 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-200 text-center text-sm py-2 border-b border-yellow-200 dark:border-yellow-700">
      🚧 This site is an early stage, alpha release. Data may be incomplete and / or may be inaccurate. Use with caution. 🚧
    </div>
    

    <!-- ── Main content ───────────────────────────────────────────────────── -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 py-8">
      <slot />
    </main>

    <!-- ── Footer ────────────────────────────────────────────────────────── -->
    <footer class="border-t border-zinc-200 dark:border-zinc-800 py-6 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-zinc-400 dark:text-zinc-500">
        <span>Magento 2 &amp; MageOS compatibility matrix.</span>
        <div class="flex gap-4">
          <a href="/api/v1/results.json" class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors">JSON API</a>
          <a href="/api" class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors">API Docs</a>
        </div>
      </div>
    </footer>

    {import.meta.env.DEV && (
      <script>
        const btn = document.getElementById('dev-refresh-btn') as HTMLButtonElement | null;
        const icon = document.getElementById('dev-refresh-icon');
        if (btn) {
          btn.addEventListener('click', async () => {
            btn.disabled = true;
            btn.style.opacity = '0.6';
            if (icon) icon.style.animation = 'spin 0.8s linear infinite';
            try {
              const res = await fetch('/_refresh', { method: 'POST' });
              if (res.ok) {
                window.location.reload();
              } else {
                btn.textContent = '✗ Error';
                setTimeout(() => {
                  btn.disabled = false;
                  btn.style.opacity = '';
                  btn.innerHTML = '<svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 2.5A7 7 0 1 1 2.5 8"/><polyline points="1 2 2.5 8 8.5 6.5"/></svg> Refresh';
                }, 2000);
              }
            } catch {
              btn.textContent = '✗ Error';
              setTimeout(() => {
                btn.disabled = false;
                btn.style.opacity = '';
                btn.innerHTML = '<svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 2.5A7 7 0 1 1 2.5 8"/><polyline points="1 2 2.5 8 8.5 6.5"/></svg> Refresh';
              }, 2000);
            }
          });
        }
      </script>
    )}

    <style>
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </body>
</html>
