---
// StatusBadge.astro — renders a coloured pill for pass/fail/partial/unknown
import type { ServiceStatus } from '@lib/types.js';

interface Props {
  status: ServiceStatus;
  label?: string;
  passed?: number;
  total?: number;
  href?: string;
  size?: 'sm' | 'md';
}

const { status, label, passed, total, href, size = 'md' } = Astro.props;

const classes: Record<ServiceStatus, string> = {
  pass: 'bg-emerald-100 text-emerald-800 ring-emerald-200 dark:bg-emerald-900/40 dark:text-emerald-300 dark:ring-emerald-700',
  fail: 'bg-rose-100 text-rose-800 ring-rose-200 dark:bg-rose-900/40 dark:text-rose-300 dark:ring-rose-700',
  partial: 'bg-amber-100 text-amber-800 ring-amber-200 dark:bg-amber-900/40 dark:text-amber-300 dark:ring-amber-700',
  unknown: 'bg-zinc-100 text-zinc-500 ring-zinc-200 dark:bg-zinc-800 dark:text-zinc-400 dark:ring-zinc-700',
};

const icons: Record<ServiceStatus, string> = {
  pass: '✓',
  fail: '✗',
  partial: '~',
  unknown: '?',
};

const sizeClass = size === 'sm' ? 'px-2 py-0.5 text-xs' : 'px-2.5 py-1 text-xs font-medium';

function buildText(): string {
  if (label) return label;
  if (status === 'partial' && passed !== undefined && total !== undefined) {
    return `${passed}/${total}`;
  }
  return status;
}

const text = buildText();
const combinedClass = `inline-flex items-center gap-1 rounded-full ring-1 ring-inset ${sizeClass} ${classes[status]}`;
---

{href ? (
  <a href={href} class={`${combinedClass} hover:opacity-80 transition-opacity`} title={`${status}${passed !== undefined ? ` (${passed}/${total} pass)` : ''}`}>
    <span aria-hidden="true">{icons[status]}</span>
    <span>{text}</span>
  </a>
) : (
  <span class={combinedClass} title={`${status}${passed !== undefined ? ` (${passed}/${total} pass)` : ''}`}>
    <span aria-hidden="true">{icons[status]}</span>
    <span>{text}</span>
  </span>
)}
